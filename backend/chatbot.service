[Unit]
Description=Chatbot Backend API
After=network.target

[Service]
Type=spawn
User=root
WorkingDirectory=/var/www/portfolio/backend
ExecStart=/var/www/portfolio/backend/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload
Restart=always
RestartSec=10
Environment=PYTHONPATH=/var/www/portfolio/backend

[Install]
WantedBy=multi-user.target